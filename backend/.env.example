# Database Config (Default for local development)
DATABASE_URL=postgresql://postgres:root@localhost:5432/tnp_portal

# App Settings
SECRET_KEY=change-this-to-a-secure-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENV=development

# Third-Party API Keys
GROQ_API_KEY=your-groq-api-key-here
BREVO_API_KEY=your-brevo-api-key-here
BREVO_SENDER_EMAIL=tnp@college.edu

# CORS Configurations
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:80,http://localhost
